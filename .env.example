# Copy this file to .env.testnet and fill in real values.
# .env.testnet is git-ignored — NEVER commit secret keys.

# Network
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Public addresses (G...)
OPERATOR_ADDRESS=
AGENT_ADDRESS=
AUDITOR_ADDRESS=
CHALLENGER_ADDRESS=
COUNTERPARTY_ADDRESS=

# Secret keys (S...) — keep private, never commit
OPERATOR_SECRET=
AGENT_SECRET=
AUDITOR_SECRET=
CHALLENGER_SECRET=
COUNTERPARTY_SECRET=

# Contract addresses (C...) — filled after deploy
RESERVE_VAULT_ADDRESS=
AUDITOR_STAKING_ADDRESS=
FEE_ESCROW_ADDRESS=
CHALLENGE_MANAGER_ADDRESS=
REGISTRY_ADDRESS=

# USDC token on Stellar testnet (Circle SAC)
USDC_ADDRESS=CBIBCQ6EIQX3DU2SIJ3MFN7MQBNXBCETNLTFHNQOSTTLZDSGQLENPVWV

# API keys
# Direct Anthropic key (sk-ant-...) or a gateway key (e.g. openllm.sh sk-llm-...).
ANTHROPIC_API_KEY=sk-ant-...
# Optional: Anthropic-compatible gateway base URL (ends in /v1). Leave unset for
# Anthropic directly. For openllm.sh use: https://openllm.sh/v1
# ANTHROPIC_BASE_URL=https://openllm.sh/v1
